# ==============================================
# Blog Platform - Environment Configuration
# ==============================================
# Copy this file to .env.local and fill in your values
# ⚠️ Never commit .env.local to version control

# ==============================================
# Database Configuration
# ==============================================
# MongoDB connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name
# Get from MongoDB Atlas dashboard
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/blog-platform?retryWrites=true&w=majority

# ==============================================
# Authentication Configuration
# ==============================================
# JWT secret for token signing
# Must be at least 32 characters long
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your_jwt_secret_key_here_minimum_32_characters

# ==============================================
# Cloudinary Configuration
# ==============================================
# Image hosting and optimization service
# Sign up at: https://cloudinary.com
# Get credentials from dashboard

# Your Cloudinary cloud name
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Cloudinary API key
CLOUDINARY_API_KEY=your_api_key

# Cloudinary API secret (keep confidential)
CLOUDINARY_API_SECRET=your_api_secret

# ==============================================
# Application Configuration
# ==============================================
# Environment type: development, production, staging
NODE_ENV=development

# Application base URL
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================================
# Optional Configuration
# ==============================================
# Database debugging (set to true for query logging)
DEBUG=false

# API rate limiting (requests per minute)
RATE_LIMIT=100

# Session expiration time in hours
SESSION_EXPIRY=24

# ==============================================
# Third-party Services (Optional)
# ==============================================
# OpenAI API key (if using AI features)
# OPENAI_API_KEY=your_openai_key

# Email service configuration (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# Analytics
# GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
